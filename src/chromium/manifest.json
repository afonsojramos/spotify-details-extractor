{
  "manifest_version": 3,
  "name": "Spotify Details Extractor",
  "description": "Extract the most important details of an album to the desired JSON.",
  "version": "2.5.0",
  "homepage_url": "https://github.com/afonsojramos/spotify-details-extractor",
  "action": {},
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["scripting", "tabs", "contextMenus", "notifications"],
  "host_permissions": ["*://*.spotify.com/*"],
  "icons": {
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png"
  }
}
