{
  "manifest_version": 3,
  "name": "Album Details Extractor",
  "description": "Extract the most important details of an album (Spotify, Qobuz) to the desired JSON.",
  "version": "4.0.0",
  "homepage_url": "https://github.com/afonsojramos/album-details-extractor",
  "action": {},
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["scripting", "tabs", "contextMenus", "notifications", "activeTab"],
  "icons": {
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png"
  }
}
